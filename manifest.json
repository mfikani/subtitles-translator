{
  "manifest_version": 3,
  "name": "YouTube Subtitle Translator",
  "version": "1.0",
  "description": "Translate YouTube subtitles in real time",
  
  "permissions": ["activeTab"],
  
  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}